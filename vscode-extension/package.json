{
  "name": "codescope",
  "displayName": "Codescope",
  "description": "Code intelligence powered by knowledge graphs — see callers, callees, and impact analysis inline",
  "version": "0.5.0",
  "publisher": "onur-gokyildiz-bhi",
  "repository": "https://github.com/onur-gokyildiz-bhi/codescope",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Other"],
  "activationEvents": ["onLanguage:*"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "codescope.index", "title": "Codescope: Index Project" },
      { "command": "codescope.search", "title": "Codescope: Search Functions" },
      { "command": "codescope.stats", "title": "Codescope: Show Stats" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
